<!-- lijst van members komt binnen -->
@model IEnumerable<SportsClub.WebApp.Models.Member>

@{
    ViewData["Title"] = "Lijst leden";
}

<h1>Lijst leden</h1>

<p>
    <!-- deze link zoekt naar een Create methode in MembersController -->
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @* @Html.DisplayNameFor(model => model.FirstName) *@
                Voornaam
            </th>
            <th>
                @* @Html.DisplayNameFor(model => model.LastName) *@
                Achternaam
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FirstName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LastName)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MemberId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.MemberId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.MemberId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
